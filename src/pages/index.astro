---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, skills, skillCategories } from '../data/site';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featuredProjects = allProjects
	.filter((p) => p.data.featured)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const latestPosts = (await getCollection('blog', ({ data }) => !data.draft))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const marqueeSkills = [...skills, ...skills];

function formatDate(date: Date) {
	return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout title={site.name} description={site.description}>
	<!-- ============ 白色块：Hero（照片 + 大字） ============ -->
	<section class="py-16 sm:py-24">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="grid items-center gap-12 sm:grid-cols-2">
				<div>
					<p class="section-index reveal mb-5">{site.title}</p>
					<h1 class="display-title reveal text-5xl sm:text-6xl lg:text-7xl">
						你好，<br />我是{site.name}。
					</h1>
					<p class="reveal mt-6 max-w-md text-lg leading-relaxed text-muted">
						{site.tagline}
					</p>
					<div class="reveal mt-9 flex flex-wrap items-center gap-4">
						<a
							href="/projects"
							class="rounded-full bg-accent px-7 py-3 text-sm font-semibold text-white hover:bg-accent-hover"
						>
							查看作品
						</a>
						<a href="/about" class="link-blue text-sm">
							进一步了解 →
						</a>
					</div>
				</div>

				<!-- 照片 -->
				<div class="reveal order-first sm:order-none">
					<div class="tile overflow-hidden p-0">
						<img
							src={site.avatar}
							alt={`${site.name} 的照片`}
							class="aspect-[4/5] w-full object-cover"
							width="560"
							height="700"
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ 黑色块：精选作品 ============ -->
	<section class="band-ink py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="reveal mb-12 sm:mb-16">
				<p class="section-index mb-4">Selected Works</p>
				<h2 class="display-title text-3xl sm:text-5xl">精选作品。</h2>
			</div>

			<div class="grid gap-5 sm:grid-cols-3">
				{
					featuredProjects.map((project, i) => (
						<a
							href={`/projects/${project.id}`}
							class:list={[
								'card-on-ink group block overflow-hidden rounded-[1.75rem] transition-all duration-300 hover:-translate-y-1.5',
								i === 0 && 'sm:col-span-2',
							]}
						>
							<div class="overflow-hidden">
								{project.data.image ? (
									<img
										src={project.data.image}
										alt={project.data.title}
										class:list={[
											'w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]',
											i === 0 ? 'aspect-[16/9]' : 'aspect-[16/10]',
										]}
									/>
								) : (
									<div class="flex aspect-[16/10] items-center justify-center text-4xl opacity-40">📦</div>
								)}
							</div>
							<div class="p-7">
								<h3 class="text-xl font-semibold tracking-tight group-hover:text-accent">
									{project.data.title}
								</h3>
								<p class="mt-2 line-clamp-2 text-sm leading-relaxed text-[var(--color-on-ink-muted)]">
									{project.data.description}
								</p>
							</div>
						</a>
					))
				}
			</div>

			<div class="reveal mt-10">
				<a href="/projects" class="link-blue text-sm">查看全部作品 →</a>
			</div>
		</div>
	</section>

	<!-- ============ 白色块：技能（填色瓦片） ============ -->
	<section class="py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="reveal mb-12 sm:mb-16 text-center">
				<p class="section-index mb-4">Capabilities</p>
				<h2 class="display-title text-3xl sm:text-5xl">能做什么。</h2>
			</div>

			<div class="grid gap-5 sm:grid-cols-3">
				{
					skillCategories.map((cat) => (
						<div class="tile reveal p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-16px_rgba(0,0,0,0.18)]">
							<h3 class="text-xl font-semibold tracking-tight">{cat.title}</h3>
							<ul class="mt-5 space-y-2.5">
								{cat.items.map((item) => (
									<li class="flex items-center gap-2.5 text-sm text-muted">
										<span class="h-1 w-1 rounded-full bg-accent" />
										{item}
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- ============ 黑色条：技能跑马灯 ============ -->
	<div class="band-ink overflow-hidden py-5" aria-label="技能一览">
		<div class="marquee-track items-center gap-10">
			{
				marqueeSkills.map((skill) => (
					<span class="flex shrink-0 items-center gap-10">
						<span class="text-sm font-medium uppercase tracking-[0.15em]">{skill.name}</span>
						<span class="h-1 w-1 rounded-full bg-accent" />
					</span>
				))
			}
		</div>
	</div>

	<!-- ============ 白色块：最新文章 ============ -->
	<section class="py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="reveal mb-12 sm:mb-16">
				<p class="section-index mb-4">Journal</p>
				<h2 class="display-title text-3xl sm:text-5xl">最新文章。</h2>
			</div>

			<div class="grid gap-5 sm:grid-cols-3">
				{
					latestPosts.map((post) => (
						<a
							href={`/blog/${post.id}`}
							class="tile group flex flex-col p-8 transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_40px_-16px_rgba(0,0,0,0.18)]"
						>
							<time
								class="text-xs font-medium text-muted"
								datetime={post.data.pubDate.toISOString()}
							>
								{formatDate(post.data.pubDate)}
							</time>
							<h3 class="mt-3 text-xl font-semibold leading-snug tracking-tight group-hover:text-accent">
								{post.data.title}
							</h3>
							<p class="mt-3 line-clamp-3 flex-1 text-sm leading-relaxed text-muted">
								{post.data.description}
							</p>
							<p class="link-blue mt-5 text-sm">阅读全文 →</p>
						</a>
					))
				}
			</div>

			<div class="reveal mt-10 text-center">
				<a href="/blog" class="link-blue text-sm">浏览全部文章 →</a>
			</div>
		</div>
	</section>
</BaseLayout>
