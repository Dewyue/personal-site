---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, aboutStory, skillCategories, timeline } from '../data/site';
---

<BaseLayout title="关于我" description={`了解 ${site.name} 的故事、经历与技能。`}>
	<!-- 白色块：页首 -->
	<section class="py-16 sm:py-24">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<p class="section-index reveal mb-5">About</p>
			<h1 class="display-title reveal max-w-3xl text-4xl sm:text-6xl">
				工程与设计，<br />两种语言，一个目标。
			</h1>
			<p class="reveal mt-8 max-w-2xl text-xl leading-relaxed text-muted">{aboutStory.intro}</p>
		</div>
	</section>

	<!-- 白色块：照片 + 故事（填色瓦片） -->
	<section class="pb-20 sm:pb-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="grid gap-5 sm:grid-cols-5">
				<div class="tile reveal overflow-hidden p-0 sm:col-span-2">
					<img
						src={site.avatar}
						alt={`${site.name} 的照片`}
						class="h-full min-h-72 w-full object-cover"
						width="450"
						height="560"
					/>
				</div>
				<div class="tile reveal p-8 sm:col-span-3 sm:p-12">
					<div class="space-y-5">
						{
							aboutStory.paragraphs.map((p) => (
								<p class="leading-loose text-muted first:text-lg first:font-medium first:text-foreground">{p}</p>
							))
						}
					</div>
					<p class="mt-8 text-sm font-semibold">{site.title} · {site.location}</p>
				</div>
			</div>
		</div>
	</section>

	<!-- 黑色块：职业时间线 -->
	<section class="band-ink py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="reveal mb-12 sm:mb-16">
				<p class="section-index mb-4">Timeline</p>
				<h2 class="display-title text-3xl sm:text-5xl">走过的路。</h2>
			</div>

			<div class="grid gap-5 sm:grid-cols-3">
				{
					timeline.map((item) => (
						<div class="card-on-ink reveal rounded-[1.75rem] p-8 transition-transform duration-300 hover:-translate-y-1">
							<p class="text-sm font-semibold text-accent">{item.year}</p>
							<h3 class="mt-3 text-xl font-semibold tracking-tight">{item.title}</h3>
							<p class="mt-1 text-sm text-[var(--color-on-ink-muted)]">{item.company}</p>
							<p class="mt-4 text-sm leading-relaxed text-[var(--color-on-ink-muted)]">{item.description}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<!-- 白色块：技能地图 -->
	<section class="py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="reveal mb-12 sm:mb-16 text-center">
				<p class="section-index mb-4">Capabilities</p>
				<h2 class="display-title text-3xl sm:text-5xl">技能地图。</h2>
			</div>

			<div class="grid gap-5 sm:grid-cols-3">
				{
					skillCategories.map((cat) => (
						<div class="tile reveal tile-hover p-8">
							<h3 class="text-xl font-semibold tracking-tight">{cat.title}</h3>
							<ul class="mt-5 space-y-2.5">
								{cat.items.map((item) => (
									<li class="flex items-center gap-2.5 text-sm text-muted">
										<span class="h-1 w-1 rounded-full bg-accent" />
										{item}
									</li>
								))}
							</ul>
						</div>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>
