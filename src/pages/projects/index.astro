---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

function formatDate(date: Date) {
	return date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long' });
}
---

<BaseLayout title="作品集" description="项目与作品展示 — 全栈开发、设计系统、开源贡献。">
	<!-- 白色块：页首 -->
	<section class="py-16 sm:py-24">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<p class="section-index reveal mb-5">Works · {projects.length} Projects</p>
			<h1 class="display-title reveal text-4xl sm:text-6xl">作品集。</h1>
			<p class="reveal mt-6 max-w-xl text-lg text-muted">
				以下是我参与或主导的部分项目，涵盖 Web 应用、设计系统与开源工具。
			</p>
		</div>
	</section>

	<!-- 黑色块：作品网格 -->
	<section class="band-ink py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-4 sm:px-6">
			<div class="grid gap-5 sm:grid-cols-2">
				{
					projects.map((project, i) => (
						<a
							href={`/projects/${project.id}`}
							class:list={[
								'card-on-ink group block overflow-hidden rounded-[1.75rem] transition-all duration-300 hover:-translate-y-1.5',
								i % 3 === 0 && 'sm:col-span-2',
							]}
						>
							<div class="relative overflow-hidden">
								{project.data.image ? (
									<img
										src={project.data.image}
										alt={project.data.title}
										class:list={[
											'w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]',
											i % 3 === 0 ? 'aspect-[21/9]' : 'aspect-[16/10]',
										]}
									/>
								) : (
									<div class="flex aspect-[16/10] items-center justify-center text-4xl opacity-40">📦</div>
								)}
								{project.data.featured && (
									<span class="absolute left-5 top-5 rounded-full bg-accent px-3.5 py-1 text-xs font-semibold text-white">
										精选
									</span>
								)}
							</div>
							<div class="p-7 sm:p-8">
								<div class="flex items-baseline justify-between gap-3">
									<h2 class="text-xl font-semibold tracking-tight group-hover:text-accent sm:text-2xl">
										{project.data.title}
									</h2>
									<span class="shrink-0 text-xs text-[var(--color-on-ink-muted)]">
										{formatDate(project.data.pubDate)}
									</span>
								</div>
								<p class="mt-2.5 line-clamp-2 text-sm leading-relaxed text-[var(--color-on-ink-muted)]">
									{project.data.description}
								</p>
								<div class="mt-4 flex flex-wrap gap-2">
									{project.data.tags.map((tag) => (
										<span class="rounded-full bg-[var(--color-surface)]/10 px-3 py-1 text-xs text-[var(--color-on-ink-muted)]">
											{tag}
										</span>
									))}
								</div>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>
</BaseLayout>
