---
interface Props {
	title?: string;
	subtitle?: string;
	index?: string;
	eyebrow?: string;
	centered?: boolean;
	class?: string;
}

const { title, subtitle, index, eyebrow, centered = false, class: className } = Astro.props;
---

<section class:list={['py-20 sm:py-28', className]}>
	<div class="mx-auto max-w-6xl px-4 sm:px-6">
		{
			(title || subtitle) && (
				<div class:list={['reveal mb-12 sm:mb-16', centered && 'text-center']}>
					{eyebrow && <p class="section-index mb-4">{eyebrow}</p>}
					{title && <h2 class="display-title text-3xl sm:text-5xl">{title}</h2>}
					{subtitle && (
						<p class:list={['mt-4 max-w-xl text-lg text-muted', centered && 'mx-auto']}>{subtitle}</p>
					)}
				</div>
			)
		}
		<slot />
	</div>
</section>
