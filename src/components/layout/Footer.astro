---
import { site, nav } from '../../data/site';

const year = new Date().getFullYear();

const socials = [
	{ label: 'GitHub', href: site.social.github },
	{ label: 'Twitter / X', href: site.social.twitter },
	{ label: 'LinkedIn', href: site.social.linkedin },
] as const;
---

<footer class="band-ink">
	<div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28">
		<!-- 大字号邀约 -->
		<div class="mb-16">
			<p class="section-index mb-5">Contact</p>
			<a href="/contact" class="display-title group inline-block text-4xl sm:text-6xl lg:text-7xl">
				来聊聊吧
				<span class="ml-1 inline-block text-accent transition-transform duration-300 group-hover:translate-x-2">→</span>
			</a>
			<p class="mt-6 max-w-md text-[15px] leading-relaxed text-[var(--color-on-ink-muted)]">
				{site.tagline}
			</p>
		</div>

		<div class="grid gap-10 pt-4 sm:grid-cols-3">
			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-on-ink-muted)]">导航</p>
				<ul class="mt-4 space-y-2.5">
					{
						nav.map((item) => (
							<li>
								<a href={item.href} class="text-sm text-[var(--color-on-ink-muted)] hover:text-[var(--color-surface)]">
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-on-ink-muted)]">社交</p>
				<ul class="mt-4 space-y-2.5">
					{
						socials.map((s) => (
							<li>
								<a
									href={s.href}
									target="_blank"
									rel="noopener noreferrer"
									class="text-sm text-[var(--color-on-ink-muted)] hover:text-[var(--color-surface)]"
								>
									{s.label}
								</a>
							</li>
						))
					}
					<li>
						<span class="text-sm text-[var(--color-on-ink-muted)]">微信：{site.social.wechat}</span>
					</li>
				</ul>
			</div>

			<div>
				<p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-on-ink-muted)]">信息</p>
				<ul class="mt-4 space-y-2.5">
					<li>
						<a href={`mailto:${site.email}`} class="text-sm text-[var(--color-on-ink-muted)] hover:text-[var(--color-surface)]">
							{site.email}
						</a>
					</li>
					<li><span class="text-sm text-[var(--color-on-ink-muted)]">{site.location}</span></li>
					<li>
						<a href="/rss.xml" class="text-sm text-[var(--color-on-ink-muted)] hover:text-[var(--color-surface)]">RSS 订阅</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="mt-16 flex flex-col items-start justify-between gap-3 border-t border-[var(--color-on-ink-muted)]/20 pt-8 sm:flex-row sm:items-center">
			<p class="text-xs text-[var(--color-on-ink-muted)]">© {year} {site.name}. 保留所有权利。</p>
			<p class="text-xs text-[var(--color-on-ink-muted)]">Designed & built with care.</p>
		</div>
	</div>
</footer>
